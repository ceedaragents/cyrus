{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": ["**", "!**/dist-electron", "!**/.cursor"]
	},
	"linter": {
		"rules": {
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noArrayIndexKey": "off",
				"noUnsafeDeclarationMerging": "off"
			}
		},
		"domains": {
			"react": "recommended",
			"test": "recommended"
		}
	},
	"overrides": [
		{
			"includes": ["apps/dashboard/src/index.css"],
			"linter": {
				"rules": {
					"suspicious": {
						"noUnknownAtRules": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/dashboard/src/**"],
			"linter": {
				"rules": {
					"a11y": {
						"useButtonType": "off",
						"noLabelWithoutControl": "off",
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off"
					},
					"correctness": {
						"useExhaustiveDependencies": "off"
					}
				}
			}
		}
	],
	"formatter": {
		"formatWithErrors": true
	},
	"vcs": {
		"enabled": true,
		"useIgnoreFile": true,
		"clientKind": "git",
		"defaultBranch": "main"
	}
}
